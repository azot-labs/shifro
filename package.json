{
  "name": "shifro",
  "version": "1.1.0",
  "description": "A lightweight library for decrypting MP4 files, directly in the browser",
  "files": [
    "dist"
  ],
  "scripts": {
    "start": "node ./dist/cli.mjs",
    "web": "vite",
    "build": "pnpm run bundle:lib && pnpm run bundle:cli",
    "bundle:lib": "tsdown ./src/index.ts --format esm --dts --platform neutral --fixed-extension",
    "bundle:cli": "tsdown ./src/cli.ts --format esm --no-clean",
    "build:cli": "pnpm run build:cli:mac && pnpm run build:cli:linux && pnpm run build:cli:win",
    "build:cli:mac": "bun build --compile --minify --bytecode --target=bun-darwin-arm64 ./src/cli.ts --outfile shifro-windows.exe",
    "build:cli:linux": "bun build --compile --minify --bytecode --target=bun-linux-x64 ./src/cli.ts --outfile shifro-linux",
    "build:cli:win": "bun build --compile --minify --bytecode --target=bun-windows-x64 ./src/cli.ts --outfile shifro-macos",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt --check .",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "prepublishOnly": "pnpm run build"
  },
  "bin": {
    "shifro": "./dist/cli.mjs"
  },
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "module-sync": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/azot-labs/shifro.git"
  },
  "keywords": [
    "mp4",
    "mpeg",
    "cenc",
    "cbcs",
    "decrypt",
    "decryption",
    "decrypter",
    "decryptor",
    "dash",
    "drm",
    "mp4decrypt",
    "mp4box",
    "shaka",
    "shaka-packager"
  ],
  "bugs": {
    "url": "https://github.com/azot-labs/shifro/issues",
    "email": "vitalygashkov@vk.com"
  },
  "author": "Vitaly Gashkov <vitalygashkov@vk.com>",
  "license": "MIT",
  "packageManager": "pnpm@10.28.1",
  "readmeFilename": "README.md",
  "funding": [
    {
      "type": "individual",
      "url": "https://t.me/tribute/app?startapp=dqW2"
    }
  ],
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "mediabunny": "^1.42.0-beta.7"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "tsdown": "^0.21.10",
    "typescript": "~6.0.3",
    "vitest": "^4.1.5"
  }
}
